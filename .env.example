# ─── Crundi Configuration ───

# ─── Telegram (required) ───
# Bot token from @BotFather — used for Login Widget validation + notifications
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Your Telegram username — only this user can access Crundi
ALLOWED_USERNAME=your-telegram-username

# ─── Project folders ───
# Two modes:
#   Single mode: Set PROJECTS_DIR to a root directory. Each subfolder is
#     auto-discovered. New projects are created as subfolders here.
#     e.g. PROJECTS_DIR=C:\Projects → subfolders Gova/, Molhu/ auto-appear.
#   Multi mode:  Leave PROJECTS_DIR empty. Projects are added individually
#     with their full paths from the web UI.
PROJECTS_DIR=C:\Projects

# ─── Web server ───
# Port for the web UI (0 = auto-assign). Tunnel runs on top of this.
WEB_PORT=0

# ─── Cloudflare Tunnel (optional) ───
# For a persistent custom domain instead of random trycloudflare.com URLs.
# Create a named tunnel in Cloudflare Zero Trust → Networks → Tunnels,
# then paste the token and your public URL here.
# If left empty, Crundi uses a random quick tunnel (no account needed).
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_URL=

# ─── Data storage ───
# Override data directory (defaults to platform-specific app dir)
# Windows: %APPDATA%/Crundi/data
# macOS:   ~/Library/Application Support/Crundi/data
# Linux:   ~/.config/crundi/data
DATA_DIR=
